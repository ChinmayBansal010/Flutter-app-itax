  "license": "ISC",
  "devDependencies": {
    "@types/node": "^14.14.16",
    "firebase": "^8.2.6",
    "firebase-admin": "^9.4.2",
    "firesql": "^2.0.2",
    "rimraf": "^3.0.2",
    "rxfire": "^4.0.0",
    "rxjs": "^6.6.3",
    "shx": "^0.3.3",
    "tharak-query": "0.0.27",
    "typescript": "^4.1.3"
  }
}
