{
  "name": "cloud-firestore",
  "version": "0.0.60",
  "description": "",
  "main": "./dist/main/firestore/store.js",
  "scripts": {
    "start": "npm run build && npm run test-copy && node --inspect dist/test/test.js --port=9010",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc && npm run copy",
    "copy": "shx cp -r ./src/main/resources/ ./dist/main/resources/",
    "test-copy": "shx cp -r ./src/test/resources/ ./dist/test/resources/",
    "test-exists": "npm run build && node dist/test/check-module.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
